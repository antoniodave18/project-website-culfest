generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model UsedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  usedAt    DateTime @default(now())
}

model Vote {
  id        String   @id @default(cuid())
  candidate String
  createdAt DateTime @default(now())
}
